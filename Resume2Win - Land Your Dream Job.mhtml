@charset "utf-8";

html, body { height: 100%; }

body.home-page { }

body.home-page main.home-main { }

body.no-scroll { overflow: hidden; height: 100vh; }

body.no-scroll header { display: none; }

body.no-scroll main { height: 100vh; overflow: hidden; padding: 0px; }

.back-button-container { padding: 1rem; background: white; border-bottom: 1=
px solid rgb(224, 224, 224); }

.back-button { display: inline-block; color: rgb(74, 144, 226); text-decora=
tion: none; font-weight: 600; font-size: 0.95rem; transition: color 0.2s; }

.back-button:hover { color: rgb(53, 122, 189); }

body { font-family: Arial, sans-serif; background: linear-gradient(135deg, =
rgb(245, 247, 250) 0%, rgb(195, 207, 226) 100%); margin: 0px; padding: 0px;=
 color: rgb(51, 51, 51); }

body.home-page header { display: none; }

header { text-align: center; padding: 1rem; background-color: white; box-sh=
adow: rgba(0, 0, 0, 0.1) 0px 2px 8px; position: sticky; top: 0px; z-index: =
1000; }

.topnav { display: flex; align-items: center; gap: 2rem; justify-content: c=
enter; max-width: 1200px; margin: 0px auto; position: relative; }

.logo-link { flex: 0 0 auto; display: flex; align-items: center; text-decor=
ation: none; }

.nav-logo { height: 50px; width: 180px; max-width: 220px; object-fit: cover=
; object-position: left center; border-radius: 6px; }

.page-title { font-size: 1.3rem; font-weight: 600; color: rgb(51, 51, 51); =
flex: 1 1 0%; text-align: center; }

.topnav .home-link { position: absolute; right: 1rem; color: rgb(74, 144, 2=
26); text-decoration: none; font-weight: 600; font-size: 0.95rem; transitio=
n: color 0.2s; }

.topnav .home-link:hover { color: rgb(53, 122, 189); }

.banner-section { width: 100%; overflow: hidden; background: white; padding=
: 0px; margin: 0px; }

.banner-image { width: 100%; height: auto; display: block; max-height: 270p=
x; object-fit: contain; }

main { padding: 1rem; }

.actions { text-align: center; margin-top: 2rem; }

button { padding: 0.8rem 1.5rem; margin: 0.5rem; border: none; background-c=
olor: rgb(255, 127, 80); color: white; font-size: 1rem; cursor: pointer; bo=
rder-radius: 4px; }

.hidden { display: none; }

#uploadForm input[type=3D"file"] { display: inline-block; }

#result { margin-top: 2rem; }

.template-grid { display: flex; gap: 1rem; flex-wrap: wrap; justify-content=
: center; }

.template-item { border: 1px solid rgb(204, 204, 204); padding: 1rem; text-=
align: center; }

.template-item img { max-width: 200px; height: auto; display: block; margin=
: 0px auto 0.5rem; }

.dragover { background-color: rgba(74, 144, 226, 0.1); }

#editor-container { height: 400px; background: white; margin-bottom: 1rem; =
}

.controls { text-align: center; margin-top: 1rem; }

.hero { display: flex; gap: 2rem; align-items: flex-start; padding: 2rem; }

.left-illustration img { max-width: 420px; width: 100%; border-radius: 8px;=
 box-shadow: rgba(0, 0, 0, 0.08) 0px 6px 18px; }

.right-panel { flex: 1 1 0%; max-width: 760px; }

.right-panel h1 { margin-top: 0px; font-size: 2rem; }

.lead { color: rgb(68, 68, 68); margin-bottom: 1rem; }

.panel { background: rgb(247, 249, 251); padding: 1rem; border-radius: 8px;=
 margin-bottom: 1rem; }

.panel.success { border-left: 6px solid rgb(52, 199, 89); }

.panel.improve { border-left: 6px solid rgb(255, 204, 0); }

.panel ul { margin: 0px; padding-left: 1.2rem; }

.actions.inline-upload { display: inline-block; margin-left: 0.5rem; }

.note { color: rgb(102, 102, 102); font-size: 0.9rem; }

.actions .btn-modern { display: inline-flex; align-items: center; gap: 0.6r=
em; padding: 0.8rem 1.2rem; border-radius: 999px; background: linear-gradie=
nt(90deg, rgb(74, 144, 226), rgb(95, 179, 255)); color: white; border: none=
; box-shadow: rgba(74, 144, 226, 0.18) 0px 6px 14px; cursor: pointer; font-=
weight: 600; }

.actions .upload-btn { display: inline-flex; align-items: center; gap: 0.6r=
em; padding: 0.6rem 0.9rem; border-radius: 999px; background: white; color:=
 rgb(74, 144, 226); border: 1px solid rgb(219, 238, 254); cursor: pointer; =
}

.inline-upload input[type=3D"file"] { display: inline-block; margin-right: =
0.5rem; }

.template-grid { display: grid; grid-template-columns: repeat(auto-fill, mi=
nmax(220px, 1fr)); gap: 1rem; padding: 1rem; }

